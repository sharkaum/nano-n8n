# ═════════════════════════════════════════════════════════════════════════════
#  nano-n8n  |  SECRET CONFIGURATION TEMPLATE
# ═════════════════════════════════════════════════════════════════════════════
#
#  ⚠️  INSTRUCTIONS:
#     1. Copy this file:  cp .env.example .env
#     2. Fill in ALL values below
#     3. NEVER commit .env to git — it is already in .gitignore
#     4. Keep this file (.env.example) in git as a reference (no real values)
#
# ═════════════════════════════════════════════════════════════════════════════


# ── PostgreSQL Database ───────────────────────────────────────────────────────
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD


# ── n8n Core Security ─────────────────────────────────────────────────────────
# Generate a strong random key:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_HEX

# n8n License / Registration key (n8n Starter, Pro or Enterprise)
N8N_LICENSE_ACTIVATION_KEY=CHANGE_ME_YOUR_LICENSE_KEY

# Basic Auth — protects the n8n web UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Owner account — used by scripts/setup-owner.sh on first boot
N8N_OWNER_EMAIL=you@example.com
N8N_OWNER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_OWNER_FIRSTNAME=Admin
N8N_OWNER_LASTNAME=Nano


# ── Network / Host ────────────────────────────────────────────────────────────
# Local access (LAN):
N8N_HOST=192.168.x.x
N8N_PROTOCOL=http
WEBHOOK_URL=http://192.168.x.x:5678/

# ── Cloudflare Tunnel (public HTTPS access) ───────────────────────────────────
# See CLOUDFLARE_SETUP.md for step-by-step instructions.
# After creating the tunnel, paste the token here and update the vars above:
#   N8N_HOST=n8n.yourdomain.com
#   N8N_PROTOCOL=https
#   WEBHOOK_URL=https://n8n.yourdomain.com/
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_YOUR_TUNNEL_TOKEN


# ── AI / LLM Provider API Keys ───────────────────────────────────────────────
# Leave blank any providers you are NOT using

# OpenAI  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic Claude  (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI / Gemini  (https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=AIza...

# Hugging Face  (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_...

# Groq  (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Ollama — local LLM running on the Jetson Nano host
# If running on the host (not inside Docker), keep the default below
OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── AI Companion Parameters ───────────────────────────────────────────────────
# See AI_COMPANION_INSTRUCTIONS.md for full documentation

# Name shown in UI and used in system prompts
AI_COMPANION_NAME=Nano

# Short persona description injected into system prompt
AI_COMPANION_PERSONA=a helpful, concise, and resourceful AI assistant

# Default provider: ollama | openai | anthropic | google | groq | huggingface
AI_DEFAULT_PROVIDER=ollama

# Default model for the chosen provider
# Ollama examples:    llama3  |  mistral  |  phi3  |  gemma2
# OpenAI examples:    gpt-4o  |  gpt-4o-mini
# Anthropic examples: claude-3-5-haiku-20241022
AI_DEFAULT_MODEL=llama3

# Enable conversation memory (stores chat history between sessions)
AI_MEMORY_ENABLED=true

# Maximum tokens in model response (lower = faster on Jetson Nano)
AI_MAX_TOKENS=2048

# Creativity level: 0.0 (deterministic) → 1.0 (creative)
AI_TEMPERATURE=0.7


# ── Timezone ─────────────────────────────────────────────────────────────────
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE=America/Sao_Paulo
